{
    "editor.rulers": [
        100
    ],
    "editor.formatOnSave": true,
    "files.insertFinalNewline": true,
    "cmake.configureOnEdit": false,
    "cmake.useCMakePresets": "always",
    "C_Cpp.codeAnalysis.clangTidy.enabled": false,
    "C_Cpp.codeAnalysis.exclude": {
        "**/build*": true
    },
    "cSpell.enabled": true,
    "cSpell.enabledFileTypes": {
        "*": true,
        "cmake": true,
        "shellscript": true,
        "markdown": true
    },
    "cSpell.words": [
        "MSVC"
    ],
    "files.associations": {
        "charconv": "cpp",
        "chrono": "cpp",
        "optional": "cpp",
        "format": "cpp",
        "ratio": "cpp",
        "system_error": "cpp",
        "array": "cpp",
        "functional": "cpp",
        "tuple": "cpp",
        "type_traits": "cpp",
        "utility": "cpp"
    }
}
